{
  "name": "wgsl-formatter",
  "displayName": "WGSL Formatter",
  "description": "Intelligent code formatter for WebGPU Shading Language (WGSL) with automatic indentation, spacing, alignment, and line wrapping",
  "version": "0.1.1",
  "publisher": "wgsl-tools",
  "author": {
    "name": "WGSL Formatter Team"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bijingdabaihua/wgsl-formatter"
  },
  "bugs": {
    "url": "https://github.com/bijingdabaihua/wgsl-formatter/issues"
  },
  "homepage": "https://github.com/bijingdabaihua/wgsl-formatter#readme",
  "keywords": [
    "wgsl",
    "webgpu",
    "shader",
    "formatter",
    "format",
    "beautify",
    "code-formatter",
    "shading-language"
  ],
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Formatters",
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:wgsl"
  ],
  "main": "./dist/extension.js",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "contributes": {
    "languages": [
      {
        "id": "wgsl",
        "extensions": [
          ".wgsl"
        ],
        "aliases": [
          "WGSL",
          "WebGPU Shading Language"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "configuration": {
      "title": "WGSL Formatter",
      "properties": {
        "wgslFormatter.indentSize": {
          "type": "number",
          "default": 4,
          "minimum": 1,
          "maximum": 8,
          "description": "Number of spaces used for each indentation level"
        },
        "wgslFormatter.useTabs": {
          "type": "boolean",
          "default": false,
          "description": "Use tabs instead of spaces for indentation"
        },
        "wgslFormatter.maxLineLength": {
          "type": "number",
          "default": 100,
          "minimum": 40,
          "maximum": 200,
          "description": "Maximum line length before automatic line wrapping is applied"
        },
        "wgslFormatter.enableLineWrapping": {
          "type": "boolean",
          "default": true,
          "description": "Enable automatic line wrapping for long lines (function signatures, expressions)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.config.js",
    "watch": "node esbuild.config.js --watch",
    "package": "vsce package",
    "publish": "vsce publish",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext ts",
    "lint:fix": "eslint src --ext ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist coverage",
    "prebuild": "npm run clean",
    "pretest": "npm run typecheck"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.75.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "@vscode/vsce": "^2.32.0",
    "esbuild": "^0.19.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "fast-check": "^3.15.0",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}